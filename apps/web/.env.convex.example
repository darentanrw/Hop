# Convex environment variables
# Set via: npx convex env set --from-file .env.convex
# (Copy to .env.convex and fill in values. Add .env.convex to .gitignore.)
#
# Generate JWT keys: pnpm convex:generate-keys (in apps/web)
#
# RESEND_INBOUND_ADDRESS: Your Resend inbound address that receives replies.
#   Create at Resend → Receiving → Add address. Replies to verification emails go here.

SITE_URL=http://localhost:3000
JWT_PRIVATE_KEY=
JWKS=
AUTH_RESEND_KEY=
RESEND_FROM_EMAIL="Hop <login@hophome.app>"
RESEND_INBOUND_ADDRESS="login@hophome.app"
MATCHER_BASE_URL="http://localhost:4001"
MATCHER_MODE="stub"
ENABLE_LOCAL_QA="false"
ADMIN_EMAILS="admin@u.nus.edu"
OPENAI_API_KEY=""
OPENAI_ADMIN_REPORT_MODEL="gpt-4.1-mini"
OPENAI_ADMIN_SUMMARY_MODEL="gpt-4.1-mini"
OPENAI_ADMIN_SUMMARY_TTL_MINUTES="15"

WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:hello@hophome.app"
