# Matcher service — copy to .env
# Loaded from services/matcher/ when running pnpm dev:matcher

MATCHER_PORT=4001
MATCHER_SEALING_KEY="dev-only-sealing-key-change-me"
MATCHER_ADMIN_PREVIEW_SECRET="replace-me"

# OneMap API — register at https://www.onemap.gov.sg/apidocs/register
# Required for geocoding + route scoring (free tier: 250 req/min)
ONEMAP_EMAIL=your-email@example.com
ONEMAP_PASSWORD=your-onemap-account-password

MATCHER_ADMIN_PREVIEW_SECRET=generated-secret-same-as-online